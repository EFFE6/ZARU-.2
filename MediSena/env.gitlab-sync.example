# Variables para sincronización con GitLab
# Copiar a env.gitlab-sync y configurar con valores reales

# GitLab API
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PROJECT_ID=12345

# Componentes técnicos del proyecto (ajustar según arquitectura)
COMPONENTS=api,signaling,webrtc,recording,auth,widget,admin,storage

# Entornos
ENVIRONMENTS=dev,staging,prod

# Restricciones conocidas
CONSTRAINTS=latency,budget,compliance

# Dependencias entre componentes (formato: componente1:componente2)
DEPENDENCIES=api:auth,widget:api,recording:webrtc
