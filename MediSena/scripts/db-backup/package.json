{
  "name": "medisena-db-backup",
  "version": "1.0.0",
  "description": "Backup Oracle -> PostgreSQL para MediSENA",
  "author": "SENA",
  "contributors": [
    { "name": "Wilson Ramirez Zuluaga", "role": "Coordinador - Iniciativa técnica" },
    { "name": "Andrés Poveda Rodríguez", "role": "DevSecOps - Arquitecto de la solución" },
    { "name": "José Luis Baquero Mora", "role": "Desarrollador" },
    { "name": "Carlos Valencia Valencia", "role": "Desarrollador" },
    { "name": "Javier Alberto Palacios Palacios", "role": "Desarrollador" },
    { "name": "Juan Carlos Sanabria", "role": "Q&A" }
  ],
  "main": "backup-oracle-to-postgres.js",
  "scripts": {
    "backup": "node backup-oracle-to-postgres.js",
    "backup:resync": "node -e \"process.env.RESYNC='1';require('./backup-oracle-to-postgres.js')\"",
    "backup:spu": "node backup-oracle-spu-to-postgres.js",
    "check:spu": "node check-oracle-spu-connection.js",
    "backup:pg-dump": "node backup-pg-dump.js",
    "verify": "node verify-migration.js",
    "verify:spu": "node -e \"process.env.VERIFY_SPU='1';require('./verify-migration.js')\"",
    "verify:full": "node verify-migration-full.js",
    "verify:full:spu": "node -e \"process.env.VERIFY_SPU='1';require('./verify-migration-full.js')\"",
    "verify:sizes": "node -e \"process.env.VERIFY_SIZES_ONLY='1';require('./verify-migration-full.js')\"",
    "verify:sizes:spu": "node -e \"process.env.VERIFY_SPU='1';process.env.VERIFY_SIZES_ONLY='1';require('./verify-migration-full.js')\"",
    "verify:sync": "node verify-sync-medisena.js",
    "validate:spu-integrity": "node validate-spu-integrity-medisena.js",
    "validate:spu-integrity:pg": "node validate-spu-integrity-medisena.js --pg-only",
    "add-missing-spu-fks": "node add-missing-spu-fks.js",
    "add-missing-spu-fks:dry": "node add-missing-spu-fks.js --dry-run",
    "normalize:iden-func-types": "node normalize-iden-func-types-medisena.js --apply",
    "normalize:iden-func-types:dry": "node normalize-iden-func-types-medisena.js --dry-run",
    "add-extra-sma-fks": "node add-extra-sma-fks.js --apply",
    "add-extra-sma-fks:dry": "node add-extra-sma-fks.js --dry-run",
    "verify:lobs": "node verify-lobs-medisena.js",
    "review:lobs": "node review-lobs-revisar.js",
    "upload:lobs": "node upload-lob-files-to-pg.js",
    "drop:empty": "node drop-empty-tables-pg.js",
    "drop:empty:list": "node drop-empty-tables-pg.js --list",
    "drop:empty:medisena": "node drop-empty-tables-medisena.js",
    "drop:empty:medisena:dry": "node drop-empty-tables-medisena.js --dry-run",
    "drop:destino": "node drop-unused-destino-tables-medisena.js",
    "drop:destino:dry": "node drop-unused-destino-tables-medisena.js --dry-run",
    "drop:dated": "node drop-dated-backup-tables-medisena.js",
    "drop:dated:dry": "node drop-dated-backup-tables-medisena.js --dry-run",
    "drop:redundant": "node drop-redundant-tables-medisena.js",
    "drop:redundant:dry": "node drop-redundant-tables-medisena.js --dry-run",
    "link:sma-cargos-t-cargos": "node link-sma-cargos-to-t-cargos.js --apply",
    "link:sma-cargos-t-cargos:dry": "node link-sma-cargos-to-t-cargos.js --dry-run",
    "fix": "node fix-migration-discrepancies.js",
    "analyze-schemas": "node analyze-schemas-sma-spu.js",
    "migrate:unified": "node migrate-to-unified-medisena.js"
  },
  "dependencies": {
    "oracledb": "^6.9.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1"
  }
}
