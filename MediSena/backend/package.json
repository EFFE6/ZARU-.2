{
  "name": "medisena-backend-api",
  "version": "1.0.0",
  "description": "MediSENA - Backend API del Sistema de Medicina Asistencial del SENA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:unit": "jest --coverage --testPathPattern=tests/",
    "test:e2e": "cross-env RUN_E2E=1 jest --testPathPattern=tests/ --verbose",
    "test:watch": "jest --watch",
    "test:parametros": "jest tests/parametros.test.js",
    "test:vigencias": "jest tests/vigencias.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security:audit-passwords": "node scripts/audit-password-storage.js",
    "security:seed-user-roles": "node scripts/seed-auth-user-roles.js --apply",
    "security:seed-user-roles:preview": "node scripts/seed-auth-user-roles.js"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "utils/**/*.js",
      "middlewares/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  },
  "keywords": [
    "medisena",
    "sena",
    "medical",
    "healthcare",
    "api",
    "backend",
    "postgresql"
  ],
  "author": "SENA",
  "license": "MIT",
  "contributors": [
    {
      "name": "Wilson Ramirez Zuluaga",
      "role": "Coordinador - Iniciativa técnica"
    },
    {
      "name": "Andrés Poveda Rodríguez",
      "role": "DevSecOps - Arquitecto de la solución"
    },
    {
      "name": "José Luis Baquero Mora",
      "role": "Desarrollador"
    },
    {
      "name": "Carlos Valencia Valencia",
      "role": "Desarrollador"
    },
    {
      "name": "Javier Alberto Palacios Palacios",
      "role": "Desarrollador"
    },
    {
      "name": "Juan Carlos Sanabria",
      "role": "Q&A"
    }
  ],
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "oracledb": "^6.9.0",
    "pg": "^8.18.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
