# Configuración SMA - Puertos Libres
# Proyecto MediSENA - SENA
# Fecha: 2025-01-27

# ===========================================
# PUERTOS LIBRES CONFIGURADOS
# ===========================================

# Aplicación Principal SMA
SMA_APP_PORT=8083
SMA_APP_URL=http://localhost:8083/sma/

# Backend API SMA
SMA_BACKEND_PORT=8081
SMA_BACKEND_URL=http://localhost:8081/

# Frontend React
SMA_FRONTEND_PORT=8080
SMA_FRONTEND_URL=http://localhost:8080/

# Servicio de Migración
SMA_MIGRATION_PORT=8085
SMA_MIGRATION_URL=http://localhost:8085/

# Oracle Database (solo para desarrollo local; sincronizacion usa ORACLE_PROD_*)
ORACLE_PORT=1522
ORACLE_HOST=localhost
ORACLE_SERVICE_NAME=SMEDICO1

# Redis
REDIS_PORT=6380
REDIS_HOST=localhost

# ===========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===========================================

# Oracle SMA - Origen remoto (maquina donde esta Oracle SMA; la sincronizacion usa estos)
ORACLE_PROD_HOST=pclu1-flptt-scan.bogrodclientpri.bogprodexa1.oraclevcn.com
ORACLE_PROD_PORT=1521
ORACLE_PROD_SERVICE_NAME=SMEDICO1_PDB_SMEDICO1.paas.oracle.com

# Oracle SPU - Origen remoto (maquina donde esta Oracle SPU; definir host, service y password)
# ORACLE_SPU_HOST=172.24.127.108
# ORACLE_SPU_PORT=1521
# ORACLE_SPU_SERVICE_NAME=SPUSMA_PDB_SPUSMA.paas.oracle.com
# ORACLE_SPU_USER=SPUSMA
# ORACLE_SPU_PASS=SPusm42023*.

# Oracle Local (Docker)
ORACLE_LOCAL_HOST=oracle-db
ORACLE_LOCAL_PORT=1521
ORACLE_LOCAL_SERVICE_NAME=SMEDICO1

# Credenciales
ORACLE_USERNAME=sma
ORACLE_PASSWORD=S3na2021

# PostgreSQL local (backup - medisena-postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=medisena
POSTGRES_PASSWORD=medisena_local
POSTGRES_DB=medisena_backup

# ===========================================
# CONFIGURACIÓN DE SERVICIOS
# ===========================================

# Java
JAVA_OPTS=-Xmx2048m -Xms1024m -XX:+UseG1GC
CATALINA_OPTS=-Djava.awt.headless=true -Dfile.encoding=UTF-8

# Node.js
NODE_ENV=development
REACT_APP_API_URL=http://localhost:8081

# ===========================================
# COMANDOS ÚTILES
# ===========================================

# Levantar SMA en puertos libres
# .\start-sma-puertos-libres.ps1

# Ver logs
# docker-compose -f docker-compose.ports-libres.yml logs -f

# Detener servicios
# docker-compose -f docker-compose.ports-libres.yml down

# Ver estado
# docker-compose -f docker-compose.ports-libres.yml ps

# ===========================================
# VERIFICACIÓN DE PUERTOS
# ===========================================

# Verificar puertos ocupados
# netstat -an | findstr LISTENING

# Verificar puertos específicos
# netstat -ano | findstr ":8083"
# netstat -ano | findstr ":8081"
# netstat -ano | findstr ":3002"
# netstat -ano | findstr ":8085"
# netstat -ano | findstr ":1522"
# netstat -ano | findstr ":6380"
