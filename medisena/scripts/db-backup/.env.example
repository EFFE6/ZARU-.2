# PostgreSQL local (destino - medisena-postgres en podman-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=medisena
POSTGRES_PASSWORD=medisena_local
POSTGRES_DB=medisena_backup
# Base donde se migrará SPU (se crea automáticamente si no existe)
POSTGRES_SPU_DB=spu_backup# Límites para LOB/archivos grandes (evitar Invalid string length y ENOBUFS)
# MAX_INSERT_VALUE_LENGTH: máximo bytes por valor al insertar en PG (default 2MB)
# ROW_THROTTLE_EVERY: pausa cada N filas en inserción fila a fila (default 50)
# ROW_THROTTLE_MS: ms de pausa (default 20)
# MAX_LOB_LENGTH: tope general al leer LOB (default 30MB)
# MAX_INSERT_VALUE_LENGTH=2097152
# ROW_THROTTLE_EVERY=50
# ROW_THROTTLE_MS=20# Fase 2: subir LOBs desde disco a la DB (upload:lobs). Máximo MB por archivo para meter en columna (default 50).
# MAX_UPLOAD_INLINE_MB=50
